7.Reverse an Array

Brute fore methof (extra array ):

class Main {
    public static void main(String[] args){
        int[] arr= {10,20,15,25};
        int[] arr2=new int [arr.length];
        int count =0;
        for(int i=arr.length-1; i>=0 ;i--){
            arr2[count]=arr[i];
            count++;
        }
        for(int i=0; i< arr.length ;i++){
             System.out.println(arr2[i]);
        }
    }
}

Two Pointer method:

class Main {
    public static void main(String[] args){
        int[] arr={10,15,20,15};
        int left=0;
        int right=arr.length-1;
        int temp;
        while(left<right){
            temp =arr[left];
            arr[left]=arr[right];
            arr[right]=temp;
            
            left++;
            right--;
        }
        for(int i=0;i<arr.length;i++){
            System.out.println(arr[i]);
        }
    }
}

8. Find 2nd max without sorting


class Main {
    public static void main(String[] args) {
       int arr[] = {25, 25, 20, 10};
       int max=arr[0];
       int max2=arr[1];
       int temp=0;
       int temp1=0;
       
       if(max2>max){
           temp=max;
           max=max2;
           max2=temp;
       }
       for(int i=2;i<arr.length;i++){
           if(arr[i]>max){
               temp1=max;
               max=arr[i];
               max2=temp1;
           }
           else if(arr[i]>max2 || arr[i]!=max){
               max2=arr[i];
           }
       }
        System.out.println(max2);
    }
}

