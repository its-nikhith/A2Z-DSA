class Main {
    public static void main(String[] args) {
        int[] arr= {10,10,20,40,5}  ;
        String a=check(arr);
        System.out.println(a);
    }
    public static String check(int arr[]){
        for(int i=0;i<arr.length-1;i++){
            if(arr[i]>arr[i+1]){
                return "Not sorted";
            }
        }
        return "Sorted";
    }
}


10. Move all zeros to the End 

Method 1 (Best approach)

class Main {
    public static void main(String[] args) {
        int[] arr= {0,10,0,29,39,40,5}  ;
        int i=0;
        for(int j=0;j<arr.length;j++){
            if(arr[j]!=0){
                arr[i]=arr[j];
                arr[j]=0;
                i++;
            }
         
        }
        for(int k=0;k<arr.length;k++){
            System.out.println(arr[k]);
        }
    }
}


